 <!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>零食飲品店</title>
    <link rel="stylesheet" href="style.css" />
</head>
<body>
    <!-- 頂部 -->
    <header>
        <div class="container header-flex">
            <h1>🍭 零食站</h1>
            <div class="header-search">
                <input type="text" id="headerSearch" placeholder="搜尋..." />
                <button>🔍</button>
            </div>
            <!-- 購物車 icon（加入 click 事件） -->
            <div class="cart-icon-wrapper" id="cartToggle">
                <span>🛒 購物車</span>
                <span class="cart-count" id="cartCount">0</span>
            </div>
        </div>
    </header>

    <!-- 導航 -->
    <nav>
        <div class="container">
            <a href="#" class="nav-link" data-category="all">🏠 首頁</a>
            <a href="#" class="nav-link" data-category="snack">零食</a>
            <a href="#" class="nav-link" data-category="drink">飲品</a>
            <a href="#" class="nav-link" data-category="all">關於我哋</a>
        </div>
    </nav>

    <!-- Banner -->
    <section class="banner">
        <div class="container">
            <h2>夏日優惠 · 全場 8 折</h2>
            <p>買滿 $200 即享折扣</p>
        </div>
    </section>

    <!-- 搜尋區 -->
    <section class="search-section">
        <div class="container">
            <div class="search-box">
                <input type="text" id="productSearch" placeholder="🔎 搜尋零食或飲品..." />
                <button id="searchBtn">搜尋</button>
            </div>
            <p id="searchResultMsg"></p>
        </div>
    </section>

    <!-- 商品陳列 -->
    <section class="products">
        <div class="container">
            <h3>🔥 人氣推介</h3>
            <div class="grid" id="productGrid">
                <!-- 商品 1：薯片（零食） -->
                <div class="card" data-name="薯片" data-category="snack" data-price="28">
                    <div class="box" style="background:#f9d56e;"></div>
                    <h4>薯片</h4>
                    <p>$28</p>
                    <button class="add-to-cart">加入購物車</button>
                </div>
                <!-- 商品 2：朱古力餅（零食） -->
                <div class="card" data-name="朱古力餅" data-category="snack" data-price="35">
                    <div class="box" style="background:#c9b1a0;"></div>
                    <h4>朱古力餅</h4>
                    <p>$35</p>
                    <button class="add-to-cart">加入購物車</button>
                </div>
                <!-- 商品 3：綠茶（飲品） -->
                <div class="card" data-name="綠茶" data-category="drink" data-price="18">
                    <div class="box" style="background:#9fd9b2;"></div>
                    <h4>綠茶</h4>
                    <p>$18</p>
                    <button class="add-to-cart">加入購物車</button>
                </div>
                <!-- 商品 4：可樂（飲品） -->
                <div class="card" data-name="可樂" data-category="drink" data-price="12">
                    <div class="box" style="background:#d4a0a0;"></div>
                    <h4>可樂</h4>
                    <p>$12</p>
                    <button class="add-to-cart">加入購物車</button>
                </div>
                <!-- 商品 5：芝士條（零食） -->
                <div class="card" data-name="芝士條" data-category="snack" data-price="22">
                    <div class="box" style="background:#f5b895;"></div>
                    <h4>芝士條</h4>
                    <p>$22</p>
                    <button class="add-to-cart">加入購物車</button>
                </div>
                <!-- 商品 6：橙汁（飲品） -->
                <div class="card" data-name="橙汁" data-category="drink" data-price="25">
                    <div class="box" style="background:#f7c35c;"></div>
                    <h4>橙汁</h4>
                    <p>$25</p>
                    <button class="add-to-cart">加入購物車</button>
                </div>
            </div>
        </div>
    </section>

    <!-- ===== 購物車側欄（預設隱藏） ===== -->
    <div id="cartSidebar" class="cart-sidebar">
        <div class="cart-sidebar-header">
            <h2>🛒 購物車</h2>
            <button id="closeCart">✕</button>
        </div>
        <div id="cartItems" class="cart-items">
            <!-- 動態生成 -->
        </div>
        <div class="cart-footer">
            <p>總計：<span id="cartTotal">$0</span></p>
            <button id="clearCart">清空購物車</button>
            <button id="checkoutBtn">結帳</button>
        </div>
    </div>
    <!-- 側欄背景遮罩 -->
    <div id="cartOverlay" class="cart-overlay"></div>

    <!-- 頁腳 -->
    <footer>
        <div class="container">
            <p>© 2026 零食站 · 靜態示範</p>
        </div>
    </footer>

    <script>
        // ============================================================
        // 1. 購物車資料（用 array 儲存）
        // ============================================================
        let cart = [];

        // ============================================================
        // 2. DOM 參考
        // ============================================================
        const cartCount = document.getElementById('cartCount');
        const cartSidebar = document.getElementById('cartSidebar');
        const cartOverlay = document.getElementById('cartOverlay');
        const cartItemsContainer = document.getElementById('cartItems');
        const cartTotal = document.getElementById('cartTotal');
        const cartToggle = document.getElementById('cartToggle');
        const closeCartBtn = document.getElementById('closeCart');
        const clearCartBtn = document.getElementById('clearCart');
        const checkoutBtn = document.getElementById('checkoutBtn');

        // ============================================================
        // 3. 加入購物車
        // ============================================================
        document.querySelectorAll('.add-to-cart').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const card = this.closest('.card');
                const name = card.dataset.name;
                const price = parseInt(card.dataset.price);

                // 檢查是否已經喺購物車
                const existing = cart.find(item => item.name === name);
                if (existing) {
                    existing.qty += 1;
                } else {
                    cart.push({ name, price, qty: 1 });
                }

                updateCartUI();
                showTemporaryMessage(`✅ ${name} 已加入購物車`);
            });
        });

        // ============================================================
        // 4. 更新購物車 UI（數字 + 側欄內容）
        // ============================================================
        function updateCartUI() {
            // 更新右上角數字
            const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);
            cartCount.textContent = totalItems;

            // 更新側欄內容
            renderCartItems();

            // 更新總金額
            const totalPrice = cart.reduce((sum, item) => sum + item.price * item.qty, 0);
            cartTotal.textContent = `$${totalPrice}`;
        }

        function renderCartItems() {
            if (cart.length === 0) {
                cartItemsContainer.innerHTML = `<p class="empty-cart">購物車目前空空如也 🛒</p>`;
                return;
            }

            let html = '';
            cart.forEach((item, index) => {
                html += `
                    <div class="cart-item">
                        <span class="cart-item-name">${item.name}</span>
                        <div class="cart-item-controls">
                            <button class="qty-btn" data-index="${index}" data-action="decrease">−</button>
                            <span class="cart-item-qty">${item.qty}</span>
                            <button class="qty-btn" data-index="${index}" data-action="increase">+</button>
                            <button class="cart-item-remove" data-index="${index}">✕</button>
                        </div>
                        <span class="cart-item-price">$${item.price * item.qty}</span>
                    </div>
                `;
            });
            cartItemsContainer.innerHTML = html;

            // 為側欄嘅按鈕加事件
            document.querySelectorAll('.qty-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const index = parseInt(this.dataset.index);
                    const action = this.dataset.action;
                    if (action === 'increase') {
                        cart[index].qty += 1;
                    } else if (action === 'decrease') {
                        cart[index].qty -= 1;
                        if (cart[index].qty <= 0) {
                            cart.splice(index, 1);
                        }
                    }
                    updateCartUI();
                });
            });

            document.querySelectorAll('.cart-item-remove').forEach(btn => {
                btn.addEventListener('click', function() {
                    const index = parseInt(this.dataset.index);
                    cart.splice(index, 1);
                    updateCartUI();
                });
            });
        }

        // ============================================================
        // 5. 打開 / 關閉側欄
        // ============================================================
        cartToggle.addEventListener('click', () => {
            cartSidebar.classList.add('open');
            cartOverlay.classList.add('show');
        });

        function closeCart() {
            cartSidebar.classList.remove('open');
            cartOverlay.classList.remove('show');
        }

        closeCartBtn.addEventListener('click', closeCart);
        cartOverlay.addEventListener('click', closeCart);

        // ============================================================
        // 6. 清空購物車
        // ============================================================
        clearCartBtn.addEventListener('click', () => {
            if (cart.length === 0) return;
            if (confirm('確定要清空購物車嗎？')) {
                cart = [];
                updateCartUI();
            }
        });

        // ============================================================
        // 7. 結帳（純提示）
        // ============================================================
        checkoutBtn.addEventListener('click', () => {
            if (cart.length === 0) {
                alert('購物車係空㗎，揀啲嘢先啦！');
                return;
            }
            alert('多謝幫襯！呢度之後會連接付款系統 💳');
            // 呢度之後可以 redirect 去 checkout page
        });

        // ============================================================
        // 8. 搜尋功能（同之前一樣）
        // ============================================================
        const searchInput = document.getElementById('productSearch');
        const cards = document.querySelectorAll('.card');
        const msg = document.getElementById('searchResultMsg');

        function filterProducts() {
            const keyword = searchInput.value.trim().toLowerCase();
            let found = 0;
            cards.forEach(card => {
                const name = card.dataset.name.toLowerCase();
                if (keyword === '' || name.includes(keyword)) {
                    card.style.display = '';
                    found++;
                } else {
                    card.style.display = 'none';
                }
            });
            msg.textContent = keyword !== '' ? `搵到 ${found} 件相關商品` : '';
        }
        searchInput.addEventListener('input', filterProducts);
        document.getElementById('searchBtn').addEventListener('click', filterProducts);

        // ============================================================
        // 9. 分類過濾（零食 / 飲品）
        // ============================================================
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const category = this.dataset.category;
                cards.forEach(card => {
                    if (category === 'all' || card.dataset.category === category) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
                // 清空搜尋框
                searchInput.value = '';
                msg.textContent = '';
                // 更新 active 樣式（可選）
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // ============================================================
        // 10. 提示訊息（短暫彈出）
        // ============================================================
        function showTemporaryMessage(text) {
            let el = document.createElement('div');
            el.className = 'toast-msg';
            el.textContent = text;
            document.body.appendChild(el);
            setTimeout(() => {
                el.remove();
            }, 1800);
        }

        // 初始化
        updateCartUI();
    </script>
</body>
</html>
